{
  "name": "sauna-plex",
  "version": "1.0.0",
  "description": "Dual-screen Plex sync menu bar app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "create-icons": "node scripts/create-icons.js",
    "build": "electron-builder"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.3.0",
    "electron-builder": "^24.13.0",
    "jest": "^29.7.0",
    "sharp": "^0.33.3"
  },
  "jest": {
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^electron$": "<rootDir>/tests/__mocks__/electron.js"
    }
  },
  "build": {
    "appId": "com.sauna-plex.app",
    "productName": "Sauna Plex",
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [{ "target": "dmg", "arch": ["universal"] }]
    },
    "files": ["main.js", "preload.js", "src/**", "renderer/**", "assets/**"],
    "extraMetadata": { "main": "main.js" }
  }
}
